<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow / glow layer (white, blurred downward) -->
    <item android:top="8dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="radial"
                android:gradientRadius="180dp"
                android:centerX="0.5"
                android:centerY="0.0"/>
            <size android:width="300dp" android:height="36dp"/>
        </shape>
    </item>

    <!-- Main curved screen line (green arc) -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#4CAF50"/>
            <size android:width="300dp" android:height="50dp"/>
        </shape>
    </item>

</layer-list>
