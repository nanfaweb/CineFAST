<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@color/black"
android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cine_text_splash"
            android:textColor="#EF4444"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fast_text_splash"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_date_text"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"/>

    <RadioGroup
        android:id="@+id/dateRadioGroup"
        android:layout_width="230sp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/radioToday"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/today_text"
            android:textColor="#FFFFFF"
            android:checked="true"
            android:background="@drawable/radio_buttons"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginEnd="14dp"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <RadioButton
            android:id="@+id/radioTomorrow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tomorrow_text"
            android:background="@drawable/radio_buttons"
            android:paddingEnd="9dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/now_showing_text"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Movie 1: Godfather -->
    <LinearLayout
        android:id="@+id/cardMovie1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/movie_card"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgGodfather"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/movie_poster_1"
            android:contentDescription="@string/movie_1_desc"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_1_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_1_details"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnBookGodfather"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/book_seats_text"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#EF4444"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnTrailerGodfather"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/trailer_text"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Movie 2: The Godfather II -->
    <LinearLayout
        android:id="@+id/cardMovie2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/movie_card"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgGodfatherII"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/movie_poster_2"
            android:contentDescription="@string/movie_2_desc"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_2_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_2_details"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnBookGodfatherII"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/book_seats_text"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#EF4444"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnTrailerGodfatherII"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/trailer_text"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Movie 3: The Godfather Part III -->
    <LinearLayout
        android:id="@+id/cardMovie3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/movie_card"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgGodfatherIII"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/movie_poster_3"
            android:contentDescription="@string/movie_3_desc"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_3_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_3_details"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnBookGodfatherIII"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/book_seats_text"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#EF4444"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnTrailerGodfatherIII"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/trailer_text"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Movie 4: The Usual Suspects -->
    <LinearLayout
        android:id="@+id/cardMovie4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/movie_card"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgUsualSuspects"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/movie_poster_4"
            android:contentDescription="@string/movie_4_desc"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_4_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_4_details"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnBookUsualSuspects"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/book_seats_text"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#EF4444"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnTrailerUsualSuspects"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/trailer_text"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Movie 5: Demon Slayer -->
    <LinearLayout
        android:id="@+id/cardMovie5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/movie_card"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgDemonSlayer"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/movie_poster_5"
            android:contentDescription="@string/movie_5_desc"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_5_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/movie_5_details"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnBookDemonSlayer"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/book_seats_text"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#EF4444"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnTrailerDemonSlayer"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="@string/trailer_text"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
</ScrollView>